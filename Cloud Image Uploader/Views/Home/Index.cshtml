@{
    ViewData["Title"] = "Upload";

    var successMessage = TempData["Success"] as string;
    var shareUrl = TempData["ShareUrl"] as string;
    var thumbnailUrl = TempData["ThumbnailUrl"] as string;
    var fileId = TempData["FileId"] as string;
    var uploadExpiresInText = TempData["ExpiresInText"] as string;
    var expiresAtText = TempData["ExpiresAtText"] as string;
    var visibilityText = TempData["VisibilityText"] as string;
    var fileName = TempData["FileName"] as string;
    var fileSize = TempData["FileSize"] as string;
    var webSize = TempData["WebSize"] as string;
    var compressionPercent = TempData["CompressionPercent"] as string;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var absoluteShareUrl = !string.IsNullOrWhiteSpace(shareUrl)
        ? $"{Context.Request.Scheme}://{Context.Request.Host}{shareUrl}"
        : string.Empty;
}

<section class="upload-center-stage">
    <section class="upload-panel upload-panel-main reveal-up">
        <div class="panel-header">
            <div>
                <span class="section-eyebrow section-eyebrow-main">Official upload portal</span>
                <p class="upload-main-subtitle">Drop an image, upload to cloud storage, and share it in seconds.</p>
            </div>
            <span class="panel-status">@(isAuthenticated ? "Signed-in mode" : "Guest mode")</span>
        </div>

        @if (isAuthenticated)
        {
            <p class="upload-mode-note">You are signed in. Set retention and visibility, then manage files in <a asp-controller="Home" asp-action="MyImages">Uploaded Images</a>.</p>
        }
        else
        {
            <p class="upload-mode-note">Guest uploads expire after 10 minutes. <a asp-controller="Account" asp-action="Login">Login</a> or <a asp-controller="Account" asp-action="Register">Register</a> for private uploads and longer retention.</p>
        }

        <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm" class="upload-form">
            @Html.AntiForgeryToken()

            <input id="fileInput" type="file" name="file" accept="image/*" class="visually-hidden" required />

            <label class="dropzone" id="dropzone" for="fileInput" tabindex="0">
                <span class="dropzone-icon"><i class="bi bi-cloud-arrow-up"></i></span>
                <span class="dropzone-title">Drag and drop a JPG, PNG, or WebP file</span>
                <span class="dropzone-subtitle">or click anywhere in this card to browse your device</span>

                <span class="selected-file" id="selectedFile" hidden>
                    <strong id="selectedFileName">No file selected</strong>
                    <span id="selectedFileMeta"></span>
                </span>
            </label>

            <div class="settings-grid">
                @if (isAuthenticated)
                {
                    <div class="setting-card">
                        <label for="retentionOption" class="form-label">Keep this upload for</label>
                        <select id="retentionOption" name="retentionOption" class="form-select">
                            <option value="10m">10 minutes</option>
                            <option value="1h">1 hour</option>
                            <option value="6h">6 hours</option>
                            <option value="1d">1 day</option>
                        </select>
                    </div>
                    <div class="setting-card">
                        <label for="visibilityOption" class="form-label">Visibility</label>
                        <select id="visibilityOption" name="visibilityOption" class="form-select">
                            <option value="private">Private (only you)</option>
                            <option value="public">Public (shareable link)</option>
                        </select>
                    </div>
                }
                else
                {
                    <div class="setting-card setting-card-wide">
                        <span class="setting-card-title">Guest upload rules</span>
                        <p>Maximum size is 10 MB and links expire in 10 minutes.</p>
                    </div>
                }
            </div>

            <div class="progress-card" id="uploadProgress" hidden>
                <div class="progress-copy-row">
                    <span id="uploadProgressLabel">Ready to upload</span>
                    <span id="uploadProgressValue">0%</span>
                </div>
                <div class="progress-track">
                    <span class="progress-fill" id="uploadProgressBar"></span>
                </div>
            </div>

            <div class="upload-actions">
                <button type="submit" class="btn-upload" id="uploadSubmitButton">
                    <span id="uploadButtonText">Upload</span>
                    <span id="uploadSpinner" class="upload-button-spinner" hidden>
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    </span>
                </button>

                <p class="upload-help-text">Supported formats: JPG, PNG, WebP.</p>
            </div>
        </form>
    </section>
</section>

@if (!string.IsNullOrWhiteSpace(successMessage) && !string.IsNullOrWhiteSpace(thumbnailUrl) && !string.IsNullOrWhiteSpace(shareUrl) && !string.IsNullOrWhiteSpace(fileId))
{
    <section class="status-panel status-panel-success">
        <div class="status-panel-header">
            <div>
                <span class="section-eyebrow">Latest upload</span>
                <h2 class="status-panel-title">Your image is ready to share.</h2>
            </div>
            <span class="status-badge success-badge"><i class="bi bi-check2-circle"></i> @successMessage</span>
        </div>

        <div class="result-grid">
            <div class="result-preview-frame">
                <img class="upload-thumbnail" src="@thumbnailUrl" alt="Thumbnail preview for @fileName" />
            </div>

            <div class="result-details">
                <div class="result-meta-grid">
                    <div class="result-meta-card">
                        <span class="result-meta-label">File</span>
                        <strong>@fileName</strong>
                    </div>
                    <div class="result-meta-card">
                        <span class="result-meta-label">Original size</span>
                        <strong>@fileSize</strong>
                    </div>
                    <div class="result-meta-card">
                        <span class="result-meta-label">Optimized size</span>
                        <strong>@webSize</strong>
                    </div>
                    <div class="result-meta-card">
                        <span class="result-meta-label">Compression</span>
                        <strong>@compressionPercent</strong>
                    </div>
                    <div class="result-meta-card">
                        <span class="result-meta-label">Visibility</span>
                        <strong>@(visibilityText ?? "Public")</strong>
                    </div>
                    <div class="result-meta-card">
                        <span class="result-meta-label">Availability</span>
                        <strong>@(uploadExpiresInText ?? "10 minutes")</strong>
                    </div>
                </div>

                <div class="share-link-section">
                    <label class="share-link-label" for="shareLinkValue">Share link</label>
                    <div class="share-link-field">
                        <input id="shareLinkValue" type="text" readonly value="@absoluteShareUrl" />
                        <button class="btn-action btn-copy" data-url="@shareUrl" type="button" onclick="copyShareLink(event)">
                            <i class="bi bi-link-45deg"></i>
                            <span>Copy</span>
                        </button>
                    </div>
                </div>

                <div class="result-note">
                    <i class="bi bi-clock-history"></i>
                    <span>Expires @(string.IsNullOrWhiteSpace(expiresAtText) ? "soon" : $"at {expiresAtText}")</span>
                </div>

                <div class="button-group upload-action-group">
                    <a href="@shareUrl" class="btn-action btn-download" target="_blank">
                        <i class="bi bi-download"></i>
                        <span>Download</span>
                    </a>
                    <button class="btn-action btn-delete" type="button" onclick="deleteFile(event, '@fileId')">
                        <i class="bi bi-trash3"></i>
                        <span>Delete</span>
                    </button>
                </div>
            </div>
        </div>
    </section>
}

@if (TempData["Error"] != null)
{
    <section class="status-panel status-panel-error">
        <div class="status-badge error-badge"><i class="bi bi-exclamation-octagon"></i> Upload failed</div>
        <p>@TempData["Error"]</p>
    </section>
}

