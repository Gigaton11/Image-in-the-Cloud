@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var isMyImagesPage = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "MyImages", StringComparison.OrdinalIgnoreCase);
    var isLoginPage = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Login", StringComparison.OrdinalIgnoreCase);
    var isRegisterPage = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Register", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kotanidis Tasos</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Cloud_Image_Uploader.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell">
        <header class="site-header">
            <div class="shell-width">
                <nav class="site-nav" aria-label="Primary">
                    <a class="site-mark" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Go to upload page">
                        <span class="site-mark-badge">Home</span>
                    </a>

                    <div class="nav-cluster nav-cluster-end">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a class="nav-pill nav-pill-circle @(isMyImagesPage ? "is-active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="MyImages">Uploaded Images</a>
                            <span class="nav-user">@User.Identity?.Name</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="nav-form">
                                <button type="submit" class="nav-pill nav-pill-button nav-pill-circle">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="nav-pill nav-pill-login @(isLoginPage ? "is-active" : string.Empty)" asp-controller="Account" asp-action="Login">Login</a>
                            <a class="nav-pill nav-pill-accent @(isRegisterPage ? "is-active" : string.Empty)" asp-controller="Account" asp-action="Register">Register</a>
                        }
                    </div>
                </nav>
            </div>
        </header>

        <main class="site-main" role="main">
            <div class="shell-width">
                @RenderBody()
            </div>
        </main>

        <footer class="site-footer footer">
            <div class="shell-width site-footer-inner">
                <span>&copy; 2026 - Kotanidis Tasos</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
