@model Cloud_Image_Uploader.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-card">
    <h1>Reset Password</h1>
    <p class="auth-subtitle">Set a new password for your account.</p>

    <form asp-action="ResetPassword" method="post" class="auth-form">
        <input asp-for="Token" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Reset Password</button>
    </form>

    <p class="auth-switch">Back to <a asp-action="Login">login</a>.</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}