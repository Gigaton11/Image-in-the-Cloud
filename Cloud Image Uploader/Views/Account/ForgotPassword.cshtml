@model Cloud_Image_Uploader.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card">
    <h1>Forgot Password</h1>
    <p class="auth-subtitle">Enter your username or email to receive a one-time password reset link.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["Error"]
        </div>
    }

    @if (TempData["ResetLink"] is string resetLink && !string.IsNullOrWhiteSpace(resetLink))
    {
        <div class="alert alert-warning" role="alert">
            <div><strong>Reset link (copy now):</strong></div>
            <a href="@resetLink">@resetLink</a>
        </div>
    }

    <form asp-action="ForgotPassword" method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Identifier" class="form-label"></label>
            <input asp-for="Identifier" class="form-control" autocomplete="username" />
            <span asp-validation-for="Identifier" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
    </form>

    <p class="auth-switch">Remembered your password? <a asp-action="Login">Back to login</a>.</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}